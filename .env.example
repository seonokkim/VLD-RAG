# Copy this file to `.env` and fill in real values locally.
# Do not commit a real `.env` file.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Used by `retriever/db_context.py` together with `configs/database.yml`.
PGPASSWORD_LOCAL=your_local_database_password

# Optional fallback used if `PGPASSWORD_LOCAL` is not set.
PGPASSWORD=

# -----------------------------------------------------------------------------
# Optional: Azure OpenAI for HyDE-style query expansion
# -----------------------------------------------------------------------------
# These values are only needed if you wire `retriever/hyde.py` to an
# Azure OpenAI-backed generator (for example, GPT-4o).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_BASE=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
